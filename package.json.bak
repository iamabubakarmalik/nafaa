{
  "name": "nafaa",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "sharp-cli": "^5.2.0",
    "tsx": "^4.21.0",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "bcrypt",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "msgpackr-extract",
      "@scarf/scarf",
      "@nestjs/core"
    ],
    "overrides": {
      "expo": "~54.0.34",
      "expo-constants": "~18.0.13",
      "expo-file-system": "~19.0.22",
      "expo-font": "~14.0.11",
      "expo-asset": "~12.0.13",
      "expo-keep-awake": "~15.0.8",
      "expo-modules-core": "~3.0.30",
      "expo-image-loader": "~6.0.0",
      "@expo/fingerprint": "~0.15.5",
      "@expo/vector-icons": "~15.1.1",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native": "0.81.5",
      "react-native-reanimated": "~4.1.7",
      "react-native-svg": "~15.12.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19.1.0",
        "react-native": "0.81.5"
      }
    }
  },
  "dependencies": {
    "sharp": "^0.33.5"
  }
}
