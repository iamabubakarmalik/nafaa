// ===================================================================
// TENANT SETTINGS — Complete configuration per shop
// ===================================================================
model TenantSettings {
  id       String @id @default(uuid())
  tenantId String @unique

  // ===== 1. BUSINESS PROFILE =====
  shopName        String?
  legalName       String?
  shopAddress     String?
  shopCity        String?
  shopProvince    String?
  shopPostalCode  String?
  shopPhone       String?
  shopWhatsapp    String?
  shopEmail       String?
  shopWebsite     String?
  logoUrl         String?
  bannerUrl       String?
  businessType    String?
  establishedDate DateTime?

  // ===== 2. LOCALIZATION =====
  language       String   @default("roman_ur") // ur, en, roman_ur
  currency       String   @default("PKR")
  currencySymbol String   @default("Rs")
  timezone       String   @default("Asia/Karachi")
  dateFormat     String   @default("DD/MM/YYYY")
  firstDayOfWeek String   @default("monday")
  openTime       String? // "09:00"
  closeTime      String? // "22:00"
  workingDays    String[] @default(["mon", "tue", "wed", "thu", "fri", "sat"])

  // ===== 3. TAX & PRICING =====
  enableTax     Boolean @default(false)
  taxRate       Float   @default(0)
  taxInclusive  Boolean @default(false)
  taxNumber     String?
  taxLabel      String  @default("GST")
  defaultMarkup Float   @default(0)
  roundPriceTo  Int     @default(1) // round to nearest 1, 5, 10

  // ===== 4. RECEIPT & INVOICE =====
  receiptSize         String  @default("THERMAL_58MM") // THERMAL_58MM, THERMAL_80MM, A4_BASIC, A4_DETAILED
  receiptHeader       String?
  receiptFooter       String?
  receiptShowLogo     Boolean @default(true)
  receiptShowTax      Boolean @default(true)
  receiptShowCustomer Boolean @default(true)
  receiptShowBarcode  Boolean @default(false)
  receiptShowQrCode   Boolean @default(false)
  invoicePrefix       String  @default("INV-")
  invoiceStartNumber  Int     @default(1)
  autoPrintReceipt    Boolean @default(false)
  printCopiesCount    Int     @default(1)

  // ===== 5. POS SETTINGS =====
  defaultPaymentMethod   String  @default("CASH")
  allowNegativeStock     Boolean @default(false)
  confirmBeforeCheckout  Boolean @default(true)
  requireCustomerForSale Boolean @default(false)
  allowDiscount          Boolean @default(true)
  maxDiscountPercent     Float   @default(50)
  roundTotal             Boolean @default(true)
  showProductImages      Boolean @default(true)
  enableBarcodeScanner   Boolean @default(true)
  enableQuickKeys        Boolean @default(true)

  // ===== 6. INVENTORY =====
  defaultLowStockAlert Int     @default(10)
  trackExpiry          Boolean @default(false)
  expiryWarningDays    Int     @default(30)
  stockMethod          String  @default("AVERAGE") // FIFO, LIFO, AVERAGE
  autoReorder          Boolean @default(false)
  reorderPoint         Int     @default(5)

  // ===== 7. CUSTOMER & UDHAAR =====
  allowCredit           Boolean @default(true)
  defaultCreditLimit    Float   @default(0)
  creditOverdueDays     Int     @default(30)
  enableLoyalty         Boolean @default(false)
  loyaltyPointsPerRupee Float   @default(0.01) // 1 point per Rs 100
  loyaltyRedemptionRate Float   @default(1) // 1 point = Rs 1
  autoCreateCustomer    Boolean @default(false)

  // ===== 8. NOTIFICATIONS =====
  emailNotifications    Boolean @default(true)
  smsNotifications      Boolean @default(false)
  whatsappNotifications Boolean @default(false)
  pushNotifications     Boolean @default(true)
  notifyLowStock        Boolean @default(true)
  notifyOutOfStock      Boolean @default(true)
  notifyNewSale         Boolean @default(false)
  notifyDailySummary    Boolean @default(true)
  dailySummaryTime      String  @default("21:00")
  notifyNewCustomer     Boolean @default(false)

  // ===== 9. SECURITY =====
  requirePinForVoid     Boolean @default(false)
  requirePinForDiscount Boolean @default(false)
  requirePinForRefund   Boolean @default(true)
  managerPin            String?
  autoLogoutMinutes     Int     @default(60)
  enableTwoFactor       Boolean @default(false)
  maxLoginAttempts      Int     @default(5)

  // ===== 10. APPEARANCE =====
  theme       String  @default("light") // light, dark, auto
  brandColor  String  @default("#16a34a")
  compactMode Boolean @default(false)

  // ===== METADATA =====
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// STAFF MANAGEMENT
// ═══════════════════════════════════════════════════════════════

enum StaffStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RESIGNED
}

enum SalaryType {
  MONTHLY
  DAILY
  HOURLY
  PER_TASK
  COMMISSION
  HYBRID
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum LeaveType {
  CASUAL
  SICK
  ANNUAL
  UNPAID
  EMERGENCY
  MATERNITY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SalaryPaymentStatus {
  PENDING
  PAID
  PARTIAL
  CANCELLED
}

enum StaffGender {
  MALE
  FEMALE
  OTHER
}

model Staff {
  id          String  @id @default(uuid())
  tenantId    String
  shopId      String?
  userId      String? @unique // Optional link to User account (for app login)
  staffNumber String // EMP-001

  // Personal Info
  fullName    String
  fatherName  String?
  gender      StaffGender?
  dateOfBirth DateTime?
  cnic        String? // 13 digits
  phone       String
  altPhone    String?
  email       String?
  address     String?
  city        String?

  // Emergency Contact
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?

  // Job Info
  designation String // Cashier, Manager, Helper, Driver, etc.
  department  String? // Sales, Inventory, Accounts, etc.
  joinDate    DateTime
  endDate     DateTime?
  status      StaffStatus @default(ACTIVE)

  // Salary
  salaryType SalaryType @default(MONTHLY)
  baseSalary Float      @default(0)
  // For MONTHLY: monthly amount
  // For DAILY: per day rate
  // For HOURLY: per hour rate
  // For PER_TASK: per task rate
  // For COMMISSION: percentage (stored as decimal e.g. 0.05 = 5%)

  workingHoursPerDay  Float @default(8)
  workingDaysPerMonth Int   @default(26)

  // Bank
  bankName      String?
  accountNumber String?
  iban          String?

  // Media
  avatarUrl    String?
  cnicFrontUrl String?
  cnicBackUrl  String?

  // Misc
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop           Shop?           @relation(fields: [shopId], references: [id], onDelete: SetNull)
  user           User?           @relation("StaffUser", fields: [userId], references: [id], onDelete: SetNull)
  attendances    Attendance[]
  leaves         StaffLeave[]
  salaryPayments SalaryPayment[]
  documents      StaffDocument[]

  @@unique([tenantId, staffNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([shopId])
  @@index([userId])
}

model StaffDocument {
  id         String   @id @default(uuid())
  staffId    String
  type       String // CNIC, CONTRACT, CERTIFICATE, OTHER
  title      String
  fileUrl    String
  fileName   String?
  notes      String?
  uploadedAt DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model Attendance {
  id       String   @id @default(uuid())
  tenantId String
  staffId  String
  date     DateTime @db.Date

  checkIn          DateTime?
  checkOut         DateTime?
  checkInPhotoUrl  String?
  checkOutPhotoUrl String?
  checkInLocation  String? // GPS coords or address
  checkOutLocation String?

  status        AttendanceStatus @default(PRESENT)
  workedHours   Float            @default(0)
  overtimeHours Float            @default(0)

  isLate      Boolean @default(false)
  lateMinutes Int     @default(0)
  notes       String?

  markedById String? // Admin who marked manually
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([tenantId])
  @@index([tenantId, date])
  @@index([staffId, date])
}

model StaffLeave {
  id             String      @id @default(uuid())
  tenantId       String
  staffId        String
  type           LeaveType   @default(CASUAL)
  startDate      DateTime    @db.Date
  endDate        DateTime    @db.Date
  days           Float
  reason         String?     @db.Text
  status         LeaveStatus @default(PENDING)
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([staffId])
  @@index([status])
}

model SalaryPayment {
  id            String @id @default(uuid())
  tenantId      String
  staffId       String
  paymentNumber String // PAY-001

  // Period
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  // Breakdown
  baseSalary       Float @default(0)
  daysWorked       Float @default(0)
  hoursWorked      Float @default(0)
  overtimePay      Float @default(0)
  commissionEarned Float @default(0)
  bonuses          Float @default(0)

  // Deductions
  advances        Float @default(0)
  leaveDeduction  Float @default(0)
  lateDeduction   Float @default(0)
  otherDeductions Float @default(0)

  // Totals
  grossAmount     Float @default(0)
  totalDeductions Float @default(0)
  netAmount       Float @default(0)
  paidAmount      Float @default(0)
  balanceAmount   Float @default(0)

  paymentMethod PaymentMethod       @default(CASH)
  status        SalaryPaymentStatus @default(PENDING)
  paidAt        DateTime?
  paidById      String?

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([tenantId, paymentNumber])
  @@index([tenantId])
  @@index([staffId])
  @@index([status])
  @@index([periodStart, periodEnd])
}

