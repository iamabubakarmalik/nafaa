enum EmiPlanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
}

enum EmiInstallmentStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}

model EmiPlan {
