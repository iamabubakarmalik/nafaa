generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  STAFF
  SUPER_ADMIN
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  JAZZCASH
  EASYPAISA
}

enum SaleStatus {
  COMPLETED
  VOIDED
  PARTIALLY_RETURNED
  FULLY_RETURNED
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum StockMovementType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  OPENING_BALANCE
  DAMAGE
  LOSS
  TRANSFER_IN
  TRANSFER_OUT
}

enum ExpenseStatus {
  PENDING
  PAID
  CANCELLED
}

enum CustomerLedgerType {
  SALE_CREDIT
  PAYMENT_RECEIVED
  ADJUSTMENT
  OPENING_BALANCE
  REFUND
  LOYALTY_REDEEMED
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum CashTransactionType {
  OPENING
  SALE
  EXPENSE
  CASH_IN
  CASH_OUT
  CLOSING
  REFUND
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  LOW_STOCK
  NEW_SALE
  PAYMENT_RECEIVED
  REGISTER_OPENED
  REGISTER_CLOSED
  CREDIT_ALERT
  RETURN_PROCESSED
  SUBSCRIPTION_EXPIRING
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  REFERRAL_EARNED
  REFERRAL_SIGNUP
}

enum AdminNotificationType {
  NEW_TENANT
  NEW_PAYMENT
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_CANCELLED
  REFERRAL_CONVERTED
  TENANT_SUSPENDED
  HIGH_VALUE_PAYMENT
  SYSTEM_ALERT
  USER_ACTION
  INFO
  WARNING
  ERROR
  SUCCESS
}

enum AdminNotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationChannel {
  EMAIL
  SMS
  BOTH
}

enum DeliveryStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTMENT
}

enum BillingInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  PENDING_PAYMENT
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum PaymentProvider {
  MANUAL_BANK
  JAZZCASH
  EASYPAISA
  STRIPE
  CASH
}

enum ReferralStatus {
  PENDING
  CONVERTED
  PAID
  EXPIRED
}

enum CreditType {
  REFERRAL_BONUS
  PROMOTIONAL
  REFUND
  ADJUSTMENT
}


model Plan {
  id             String  @id @default(uuid())
  name           String  @unique
  slug           String  @unique
  description    String?
  priceMonthly   Float   @default(0)
  priceQuarterly Float   @default(0)
  priceYearly    Float   @default(0)
  trialDays      Int     @default(7)
  isActive       Boolean @default(true)
  isPublic       Boolean @default(true)
  sortOrder      Int     @default(0)

  maxProducts      Int @default(50)
  maxUsers         Int @default(2)
  maxShops         Int @default(1)
  maxSalesPerMonth Int @default(500)

  featurePos             Boolean @default(true)
  featureBarcodeScanner  Boolean @default(true)
  featureMultiShop       Boolean @default(false)
  featureReports         Boolean @default(true)
  featureProfitReport    Boolean @default(false)
  featureLoyalty         Boolean @default(false)
  featureDiscounts       Boolean @default(false)
  featureKhata           Boolean @default(true)
  featureExports         Boolean @default(false)
  featureBackup          Boolean @default(false)
  featureNotifications   Boolean @default(true)
  featureCashRegister    Boolean @default(true)
  featureStockTransfer   Boolean @default(false)
  featureReturns         Boolean @default(true)
  featureSupport24x7     Boolean @default(false)
  featureWhatsappReceipt Boolean @default(false)
  featureCustomBranding  Boolean @default(false)

  stripePriceMonthlyId   String?
  stripePriceQuarterlyId String?
  stripePriceYearlyId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Tenant {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  phone         String?
  country       String       @default("Pakistan")
  currency      String       @default("PKR")
  language      String       @default("en")
  status        TenantStatus @default(TRIAL)
  referralCode  String?      @unique
  referredById  String?
  accountCredit Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  users               User[]
  products            Product[]
  customers           Customer[]
  sales               Sale[]
  suppliers           Supplier[]
  purchases           Purchase[]
  stockMovements      StockMovement[]
  categories          Category[]
  expenses            Expense[]
  expenseCategories   ExpenseCategory[]
  settings            TenantSettings?
  customerLedgers     CustomerLedger[]
  stockAdjustments    StockAdjustment[]
  shops               Shop[]
  cashRegisters       CashRegister[]
  cashTransactions    CashTransaction[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  transfers           StockTransfer[]
  returns             SaleReturn[]
  discountCodes       DiscountCode[]
  loyaltyTransactions LoyaltyTransaction[]
  subscriptions       Subscription[]
  tenantNotes         TenantNote[]
  invoices            Invoice[]
  payments            Payment[]
  uploads             Upload[]
  emailLogs           EmailLog[]
  smsLogs             SmsLog[]
  notificationPreference NotificationPreference?
  referredBy          Tenant?              @relation("TenantReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referredTenants     Tenant[]             @relation("TenantReferrals")
  referralsGiven      Referral[]           @relation("ReferralReferrer")
  referralsReceived   Referral[]           @relation("ReferralReferee")
  creditTransactions  CreditTransaction[]
}

model Referral {
  id               String         @id @default(uuid())
  referrerTenantId String
  refereeTenantId  String
  code             String
  status           ReferralStatus @default(PENDING)
  rewardAmount     Float          @default(0)
  rewardPaid       Boolean        @default(false)
  rewardPaidAt     DateTime?
  convertedAt      DateTime?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  referrer Tenant @relation("ReferralReferrer", fields: [referrerTenantId], references: [id], onDelete: Cascade)
  referee  Tenant @relation("ReferralReferee", fields: [refereeTenantId], references: [id], onDelete: Cascade)

  @@unique([refereeTenantId])
  @@index([referrerTenantId])
  @@index([status])
}

model CreditTransaction {
  id           String     @id @default(uuid())
  tenantId     String
  type         CreditType
  amount       Float
  balanceAfter Float
  reference    String?
  note         String?
  createdAt    DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String
  planId               String
  status               SubscriptionStatus @default(TRIAL)
  interval             BillingInterval    @default(MONTHLY)
  amount               Float
  currency             String             @default("PKR")
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  cancelledAt          DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  autoRenew            Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]
  payments Payment[]

  @@index([tenantId])
  @@index([status])
  @@index([currentPeriodEnd])
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  subscriptionId String?
  invoiceNumber  String        @unique
  status         InvoiceStatus @default(PENDING)
  subtotal       Float
  tax            Float         @default(0)
  total          Float
  amountPaid     Float         @default(0)
  amountDue      Float
  currency       String        @default("PKR")
  description    String?
  notes          String?
  dueDate        DateTime
  paidAt         DateTime?
  periodStart    DateTime?
  periodEnd      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payments     Payment[]

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id                    String          @id @default(uuid())
  tenantId              String
  subscriptionId        String?
  invoiceId             String?
  uploadId              String?
  amount                Float
  currency              String          @default("PKR")
  provider              PaymentProvider
  status                PaymentStatus   @default(PENDING)
  reference             String?
  bankName              String?
  accountNumber         String?
  transactionId         String?
  payerName             String?
  notes                 String?
  rejectionReason       String?
  approvedById          String?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  paidAt                DateTime?
  stripePaymentIntentId String?
  metadata              Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  upload       Upload?       @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([provider])
}

model Upload {
  id           String   @id @default(uuid())
  tenantId     String?
  uploaderId   String?
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  url          String
  purpose      String?
  metadata     Json?
  createdAt    DateTime @default(now())

  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@index([tenantId])
  @@index([purpose])
}

model TenantSettings {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  shopName            String?
  shopAddress         String?
  shopPhone           String?
  shopEmail           String?
  logoUrl             String?
  taxRate             Float    @default(0)
  taxNumber           String?
  receiptFooter       String?
  receiptHeader       String?
  enableTax           Boolean  @default(false)
  loyaltyEnabled      Boolean  @default(false)
  loyaltyPointsPerPKR Float    @default(0.01)
  loyaltyRedeemRate   Float    @default(1.0)
  loyaltyMinRedeem    Int      @default(100)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Shop {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  isMain    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashRegisters CashRegister[]
  sales         Sale[]
  transfersFrom StockTransfer[] @relation("TransfersFrom")
  transfersTo   StockTransfer[] @relation("TransfersTo")

  @@unique([tenantId, name])
  @@index([tenantId])
}

model User {
  id            String    @id @default(uuid())
  tenantId      String
  fullName      String
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  role          UserRole  @default(OWNER)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  adminNotificationsRead AdminNotification[] @relation("AdminNotifReadBy")

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions            Session[]
  otps                OtpCode[]
  salesCreated        Sale[]                  @relation("UserSales")
  purchasesMade       Purchase[]              @relation("UserPurchases")
  expensesMade        Expense[]               @relation("UserExpenses")
  adjustmentsMade     StockAdjustment[]       @relation("UserAdjustments")
  ledgersCreated      CustomerLedger[]        @relation("UserLedgers")
  cashRegistersOpened CashRegister[]          @relation("UserOpenedRegisters")
  cashRegistersClosed CashRegister[]          @relation("UserClosedRegisters")
  cashTransactions    CashTransaction[]       @relation("UserCashTx")
  activityLogs        ActivityLog[]           @relation("UserActivities")
  notifications       Notification[]          @relation("UserNotifications")
  transfersCreated    StockTransfer[]         @relation("UserTransfers")
  returnsProcessed    SaleReturn[]            @relation("UserReturns")
  discountsCreated    DiscountCode[]          @relation("UserDiscounts")
  notesAuthored       TenantNote[]            @relation("UserNotes")
  settingsUpdated     SystemSetting[]         @relation("UserSettings")
  broadcasts          BroadcastNotification[] @relation("UserBroadcasts")
  platformDiscounts   PlatformDiscount[]      @relation("UserPlatformDiscounts")

  @@index([tenantId])
  @@index([tenantId, role])
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id         String    @id @default(uuid())
  userId     String?
  email      String?
  phone      String?
  code       String
  purpose    String
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([phone])
  @@index([purpose])
}

model Category {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  color     String   @default("#2c9466")
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id            String   @id @default(uuid())
  tenantId      String
  categoryId    String?
  name          String
  sku           String?
  barcode       String?
  unit          String   @default("pcs")
  price         Float    @default(0)
  costPrice     Float    @default(0)
  stock         Int      @default(0)
  lowStockAlert Int      @default(5)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  stockMovements StockMovement[]
  adjustments    StockAdjustment[]
  transferItems  StockTransferItem[]
  returnItems    SaleReturnItem[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
  @@index([tenantId, barcode])
  @@index([categoryId])
}

model Customer {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  phone         String?
  email         String?
  address       String?
  notes         String?
  creditLimit   Float    @default(0)
  balance       Float    @default(0)
  loyaltyPoints Int      @default(0)
  totalSpent    Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales               Sale[]
  ledgers             CustomerLedger[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, phone])
}

model CustomerLedger {
  id           String             @id @default(uuid())
  tenantId     String
  customerId   String
  createdById  String?
  type         CustomerLedgerType
  amount       Float
  balanceAfter Float
  reference    String?
  note         String?
  createdAt    DateTime           @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("UserLedgers", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([customerId])
  @@index([customerId, createdAt])
}

model LoyaltyTransaction {
  id           String                 @id @default(uuid())
  tenantId     String
  customerId   String
  type         LoyaltyTransactionType
  points       Int
  balanceAfter Int
  reference    String?
  note         String?
  createdAt    DateTime               @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([customerId, createdAt])
}

model DiscountCode {
  id          String       @id @default(uuid())
  tenantId    String
  createdById String?
  code        String
  description String?
  type        DiscountType @default(PERCENTAGE)
  value       Float
  minPurchase Float        @default(0)
  maxDiscount Float?
  usageLimit  Int?
  usageCount  Int          @default(0)
  validFrom   DateTime?
  validUntil  DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("UserDiscounts", fields: [createdById], references: [id], onDelete: SetNull)
  sales     Sale[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model Sale {
  id             String        @id @default(uuid())
  tenantId       String
  shopId         String?
  cashRegisterId String?
  customerId     String?
  createdById    String?
  discountCodeId String?
  saleNumber     String
  subtotal       Float
  discount       Float         @default(0)
  discountCode   String?
  loyaltyUsed    Int           @default(0)
  loyaltyEarned  Int           @default(0)
  total          Float
  costOfGoods    Float         @default(0)
  paidAmount     Float
  changeAmount   Float         @default(0)
  creditAmount   Float         @default(0)
  refundedAmount Float         @default(0)
  paymentMethod  PaymentMethod @default(CASH)
  status         SaleStatus    @default(COMPLETED)
  soldAt         DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop            Shop?         @relation(fields: [shopId], references: [id], onDelete: SetNull)
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy       User?         @relation("UserSales", fields: [createdById], references: [id], onDelete: SetNull)
  discountCodeRef DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  items           SaleItem[]
  returns         SaleReturn[]

  @@unique([tenantId, saleNumber])
  @@index([tenantId])
  @@index([tenantId, soldAt])
  @@index([customerId])
  @@index([shopId])
  @@index([cashRegisterId])
}

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String
  productId   String
  quantity    Int
  returnedQty Int      @default(0)
  price       Float
  costPrice   Float    @default(0)
  total       Float
  createdAt   DateTime @default(now())

  sale        Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  returnItems SaleReturnItem[]

  @@index([saleId])
  @@index([productId])
}

model SaleReturn {
  id           String        @id @default(uuid())
  tenantId     String
  saleId       String
  createdById  String?
  returnNumber String
  reason       String?
  refundAmount Float
  refundMethod PaymentMethod @default(CASH)
  notes        String?
  returnedAt   DateTime      @default(now())
  createdAt    DateTime      @default(now())

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale      Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy User?            @relation("UserReturns", fields: [createdById], references: [id], onDelete: SetNull)
  items     SaleReturnItem[]

  @@unique([tenantId, returnNumber])
  @@index([tenantId])
  @@index([saleId])
  @@index([tenantId, returnedAt])
}

model SaleReturnItem {
  id          String @id @default(uuid())
  returnId    String
  saleItemId  String
  productId   String
  quantity    Int
  refundPrice Float
  total       Float

  return   SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItem SaleItem   @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  product  Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([returnId])
  @@index([saleItemId])
  @@index([productId])
}

model Supplier {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  @@index([tenantId])
  @@index([tenantId, name])
}

model Purchase {
  id             String         @id @default(uuid())
  tenantId       String
  supplierId     String
  createdById    String?
  purchaseNumber String
  subtotal       Float
  discount       Float          @default(0)
  total          Float
  paidAmount     Float          @default(0)
  paymentMethod  PaymentMethod  @default(CASH)
  status         PurchaseStatus @default(RECEIVED)
  notes          String?
  purchasedAt    DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier  Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy User?          @relation("UserPurchases", fields: [createdById], references: [id], onDelete: SetNull)
  items     PurchaseItem[]

  @@unique([tenantId, purchaseNumber])
  @@index([tenantId])
  @@index([tenantId, purchasedAt])
  @@index([supplierId])
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  costPrice  Float
  total      Float
  createdAt  DateTime @default(now())

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
}

model StockMovement {
  id           String            @id @default(uuid())
  tenantId     String
  productId    String
  type         StockMovementType
  quantity     Int
  balanceAfter Int
  reference    String?
  note         String?
  createdAt    DateTime          @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([productId])
}

model StockAdjustment {
  id          String            @id @default(uuid())
  tenantId    String
  productId   String
  createdById String?
  type        StockMovementType
  quantity    Int
  reason      String
  note        String?
  createdAt   DateTime          @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("UserAdjustments", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([productId])
  @@index([tenantId, createdAt])
}

model StockTransfer {
  id             String         @id @default(uuid())
  tenantId       String
  fromShopId     String
  toShopId       String
  createdById    String?
  transferNumber String
  status         TransferStatus @default(PENDING)
  notes          String?
  transferredAt  DateTime?
  receivedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromShop  Shop                @relation("TransfersFrom", fields: [fromShopId], references: [id])
  toShop    Shop                @relation("TransfersTo", fields: [toShopId], references: [id])
  createdBy User?               @relation("UserTransfers", fields: [createdById], references: [id], onDelete: SetNull)
  items     StockTransferItem[]

  @@unique([tenantId, transferNumber])
  @@index([tenantId])
  @@index([fromShopId])
  @@index([toShopId])
  @@index([status])
}

model StockTransferItem {
  id         String   @id @default(uuid())
  transferId String
  productId  String
  quantity   Int
  createdAt  DateTime @default(now())

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([transferId])
  @@index([productId])
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  color     String   @default("#f59e0b")
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Expense {
  id            String        @id @default(uuid())
  tenantId      String
  categoryId    String?
  createdById   String?
  expenseNumber String
  title         String
  description   String?
  amount        Float
  paymentMethod PaymentMethod @default(CASH)
  status        ExpenseStatus @default(PAID)
  expenseDate   DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?            @relation("UserExpenses", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([tenantId, expenseNumber])
  @@index([tenantId])
  @@index([tenantId, expenseDate])
  @@index([categoryId])
}

model CashRegister {
  id              String             @id @default(uuid())
  tenantId        String
  shopId          String?
  openedById      String
  closedById      String?
  registerNumber  String
  status          CashRegisterStatus @default(OPEN)
  openingBalance  Float              @default(0)
  expectedBalance Float              @default(0)
  closingBalance  Float              @default(0)
  difference      Float              @default(0)
  totalSales      Float              @default(0)
  totalCashIn     Float              @default(0)
  totalCashOut    Float              @default(0)
  totalExpenses   Float              @default(0)
  notes           String?
  openedAt        DateTime           @default(now())
  closedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop         Shop?             @relation(fields: [shopId], references: [id], onDelete: SetNull)
  openedBy     User              @relation("UserOpenedRegisters", fields: [openedById], references: [id])
  closedBy     User?             @relation("UserClosedRegisters", fields: [closedById], references: [id], onDelete: SetNull)
  transactions CashTransaction[]
  sales        Sale[]

  @@unique([tenantId, registerNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([shopId])
}

model CashTransaction {
  id             String              @id @default(uuid())
  tenantId       String
  cashRegisterId String
  createdById    String?
  type           CashTransactionType
  amount         Float
  reason         String?
  note           String?
  reference      String?
  createdAt      DateTime            @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("UserCashTx", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([cashRegisterId])
  @@index([tenantId, createdAt])
}

model ActivityLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String?
  action      String
  entityType  String?
  entityId    String?
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation("UserActivities", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  userId    String?
  type      NotificationType @default(INFO)
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([userId, isRead])
  @@index([tenantId, createdAt])
}

model TenantNote {
  id        String   @id @default(uuid())
  tenantId  String
  authorId  String
  title     String?
  content   String   @db.Text
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User   @relation("UserNotes", fields: [authorId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  category    String   @default("general")
  description String?
  isPublic    Boolean  @default(false)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation("UserSettings", fields: [updatedById], references: [id])

  @@index([category])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  subject   String
  bodyHtml  String   @db.Text
  bodyText  String?  @db.Text
  variables Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model BroadcastNotification {
  id              String   @id @default(uuid())
  authorId        String
  title           String
  message         String   @db.Text
  link            String?
  targetType      String   @default("ALL") // ALL, ACTIVE, TRIAL, SUSPENDED, SPECIFIC
  targetTenantIds String[] @default([])
  recipientCount  Int      @default(0)
  sentAt          DateTime @default(now())
  createdAt       DateTime @default(now())

  author User @relation("UserBroadcasts", fields: [authorId], references: [id])

  @@index([sentAt])
}

model PlatformDiscount {
  id              String       @id @default(uuid())
  code            String       @unique
  description     String?
  type            DiscountType @default(PERCENTAGE)
  value           Float
  scope           String       @default("PLAN") // PLAN, ANY
  applicablePlans String[]     @default([])
  minPurchase     Float        @default(0)
  maxDiscount     Float?
  usageLimit      Int?
  usageCount      Int          @default(0)
  perTenantLimit  Int?
  validFrom       DateTime?
  validUntil      DateTime?
  isActive        Boolean      @default(true)
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  createdBy User @relation("UserPlatformDiscounts", fields: [createdById], references: [id])

  @@index([code])
  @@index([isActive])
}

model EmailLog {
  id            String         @id @default(uuid())
  tenantId      String?
  templateSlug  String?
  toEmail       String
  toName        String?
  subject       String
  bodyHtml      String         @db.Text
  bodyText      String?        @db.Text
  variables     Json?
  status        DeliveryStatus @default(QUEUED)
  providerId    String?
  errorMessage  String?
  retryCount    Int            @default(0)
  sentAt        DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([toEmail])
  @@index([createdAt])
}

model SmsLog {
  id            String         @id @default(uuid())
  tenantId      String?
  templateSlug  String?
  toPhone       String
  message       String         @db.Text
  variables     Json?
  status        DeliveryStatus @default(QUEUED)
  providerId    String?
  cost          Float          @default(0)
  errorMessage  String?
  retryCount    Int            @default(0)
  sentAt        DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([toPhone])
  @@index([createdAt])
}

model SmsTemplate {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  message     String   @db.Text
  variables   Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model NotificationPreference {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(true)
  emailWelcome    Boolean  @default(true)
  emailPayment    Boolean  @default(true)
  emailExpiry     Boolean  @default(true)
  emailLowStock   Boolean  @default(true)
  emailMarketing  Boolean  @default(false)
  smsPayment      Boolean  @default(true)
  smsExpiry       Boolean  @default(true)
  smsCritical     Boolean  @default(true)
  smsMarketing    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AdminNotification {
  id          String                    @id @default(uuid())
  type        AdminNotificationType     @default(INFO)
  priority    AdminNotificationPriority @default(NORMAL)
  title       String
  message     String                    @db.Text
  link        String?
  metadata    Json?
  isRead      Boolean                   @default(false)
  readAt      DateTime?
  readById    String?
  tenantId    String?
  entityType  String?
  entityId    String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  readBy      User?                     @relation("AdminNotifReadBy", fields: [readById], references: [id], onDelete: SetNull)

  @@index([isRead])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
  @@index([tenantId])
}
