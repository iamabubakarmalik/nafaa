generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

enum ShopType {
  SHOP // Regular retail shop with POS
  WAREHOUSE // Storage only, no POS, only transfers
  GODOWN // Backup storage
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  STAFF
  SUPER_ADMIN
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  JAZZCASH
  EASYPAISA
}

enum SaleStatus {
  COMPLETED
  VOIDED
  PARTIALLY_RETURNED
  FULLY_RETURNED
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum StockMovementType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  OPENING_BALANCE
  DAMAGE
  LOSS
  TRANSFER_IN
  TRANSFER_OUT
}

enum ExpenseStatus {
  PENDING
  PAID
  CANCELLED
}

enum CustomerLedgerType {
  SALE_CREDIT
  PAYMENT_RECEIVED
  ADJUSTMENT
  OPENING_BALANCE
  REFUND
  LOYALTY_REDEEMED
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum CashTransactionType {
  OPENING
  SALE
  EXPENSE
  CASH_IN
  CASH_OUT
  CLOSING
  REFUND
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  LOW_STOCK
  NEW_SALE
  PAYMENT_RECEIVED
  REGISTER_OPENED
  REGISTER_CLOSED
  CREDIT_ALERT
  RETURN_PROCESSED
  SUBSCRIPTION_EXPIRING
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  REFERRAL_EARNED
  REFERRAL_SIGNUP
}

enum AdminNotificationType {
  NEW_TENANT
  NEW_PAYMENT
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_CANCELLED
  REFERRAL_CONVERTED
  TENANT_SUSPENDED
  HIGH_VALUE_PAYMENT
  SYSTEM_ALERT
  USER_ACTION
  INFO
  WARNING
  ERROR
  SUCCESS
}

enum AdminNotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationChannel {
  EMAIL
  SMS
  BOTH
}

enum DeliveryStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTMENT
}

enum BillingInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  PENDING_PAYMENT
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum PaymentProvider {
  MANUAL_BANK
  JAZZCASH
  EASYPAISA
  STRIPE
  CASH
}

enum ReferralStatus {
  PENDING
  CONVERTED
  PAID
  EXPIRED
}

enum CreditType {
  REFERRAL_BONUS
  PROMOTIONAL
  REFUND
  ADJUSTMENT
}

enum CustomerGender {
  MALE
  FEMALE
  OTHER
}

model Plan {
  id             String  @id @default(uuid())
  name           String  @unique
  slug           String  @unique
  description    String?
  priceMonthly   Float   @default(0)
  priceQuarterly Float   @default(0)
  priceYearly    Float   @default(0)
  trialDays      Int     @default(7)
  isActive       Boolean @default(true)
  isPublic       Boolean @default(true)
  sortOrder      Int     @default(0)

  maxProducts      Int @default(50)
  maxUsers         Int @default(2)
  maxShops         Int @default(1)
  maxSalesPerMonth Int @default(500)

  featurePos             Boolean @default(true)
  featureBarcodeScanner  Boolean @default(true)
  featureMultiShop       Boolean @default(false)
  featureReports         Boolean @default(true)
  featureProfitReport    Boolean @default(false)
  featureLoyalty         Boolean @default(false)
  featureDiscounts       Boolean @default(false)
  featureKhata           Boolean @default(true)
  featureExports         Boolean @default(false)
  featureBackup          Boolean @default(false)
  featureNotifications   Boolean @default(true)
  featureCashRegister    Boolean @default(true)
  featureStockTransfer   Boolean @default(false)
  featureReturns         Boolean @default(true)
  featureSupport24x7     Boolean @default(false)
  featureWhatsappReceipt Boolean @default(false)
  featureCustomBranding  Boolean @default(false)

  stripePriceMonthlyId   String?
  stripePriceQuarterlyId String?
  stripePriceYearlyId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Tenant {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  phone         String?
  country       String       @default("Pakistan")
  currency      String       @default("PKR")
  language      String       @default("en")
  status        TenantStatus @default(TRIAL)
  address       String?
  referralCode  String?      @unique
  referredById  String?
  accountCredit Float        @default(0)

  // ─── Business Configuration ──────────────────────────────────
  businessType     String? // CARPET, MOBILE, GROCERY, PHARMACY, etc.
  businessFeatures Json? // { lengthWidthCalc: true, imei: false, ... }
  defaultUnit      String? // sqft, kg, pcs, etc.

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  onboardingProgress OnboardingProgress[]

  users               User[]
  products            Product[]
  customers           Customer[]
  sales               Sale[]
  suppliers           Supplier[]
  purchases           Purchase[]
  stockMovements      StockMovement[]
  categories          Category[]
  expenses            Expense[]
  expenseCategories   ExpenseCategory[]
  settings            TenantSettings?
  customerLedgers     CustomerLedger[]
  stockAdjustments    StockAdjustment[]
  shops               Shop[]
  cashRegisters       CashRegister[]
  cashTransactions    CashTransaction[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  transfers           StockTransfer[]
  returns             SaleReturn[]
  discountCodes       DiscountCode[]
  loyaltyTransactions LoyaltyTransaction[]
  subscriptions       Subscription[]
  tenantNotes         TenantNote[]
  invoices            Invoice[]
  payments            Payment[]
  uploads             Upload[]
  emailLogs           EmailLog[]
  smsLogs             SmsLog[]
  brands              Brand[]
  tags                Tag[]
  productBatches      ProductBatch[]
  staff               Staff[]
  productImeis        ProductImei[]
  restaurantTables    RestaurantTable[]
  salonAppointments   SalonAppointment[]
  emiPlans            EmiPlan[]
  carpetRolls         CarpetRoll[]
  carpetCutPieces     CarpetCutPiece[]
  usedPhones          UsedPhone[]
  repairTickets       RepairTicket[]

  notificationPreference NotificationPreference?
  referredBy             Tenant?                 @relation("TenantReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referredTenants        Tenant[]                @relation("TenantReferrals")
  referralsGiven         Referral[]              @relation("ReferralReferrer")
  referralsReceived      Referral[]              @relation("ReferralReferee")
  creditTransactions     CreditTransaction[]
}

model Referral {
  id               String         @id @default(uuid())
  referrerTenantId String
  refereeTenantId  String
  code             String
  status           ReferralStatus @default(PENDING)
  rewardAmount     Float          @default(0)
  rewardPaid       Boolean        @default(false)
  rewardPaidAt     DateTime?
  convertedAt      DateTime?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  referrer Tenant @relation("ReferralReferrer", fields: [referrerTenantId], references: [id], onDelete: Cascade)
  referee  Tenant @relation("ReferralReferee", fields: [refereeTenantId], references: [id], onDelete: Cascade)

  @@unique([refereeTenantId])
  @@index([referrerTenantId])
  @@index([status])
}

model CreditTransaction {
  id           String     @id @default(uuid())
  tenantId     String
  type         CreditType
  amount       Float
  balanceAfter Float
  reference    String?
  note         String?
  createdAt    DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String
  planId               String
  status               SubscriptionStatus @default(TRIAL)
  interval             BillingInterval    @default(MONTHLY)
  amount               Float
  currency             String             @default("PKR")
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  cancelledAt          DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  autoRenew            Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]
  payments Payment[]

  @@index([tenantId])
  @@index([status])
  @@index([currentPeriodEnd])
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  subscriptionId String?
  invoiceNumber  String        @unique
  status         InvoiceStatus @default(PENDING)
  subtotal       Float
  tax            Float         @default(0)
  total          Float
  amountPaid     Float         @default(0)
  amountDue      Float
  currency       String        @default("PKR")
  description    String?
  notes          String?
  dueDate        DateTime
  paidAt         DateTime?
  periodStart    DateTime?
  periodEnd      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payments     Payment[]

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id                    String          @id @default(uuid())
  tenantId              String
  subscriptionId        String?
  invoiceId             String?
  uploadId              String?
  amount                Float
  currency              String          @default("PKR")
  provider              PaymentProvider
  status                PaymentStatus   @default(PENDING)
  reference             String?
  bankName              String?
  accountNumber         String?
  transactionId         String?
  payerName             String?
  notes                 String?
  rejectionReason       String?
  approvedById          String?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  paidAt                DateTime?
  stripePaymentIntentId String?
  metadata              Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  upload       Upload?       @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([provider])
}

model Upload {
  id           String   @id @default(uuid())
  tenantId     String?
  uploaderId   String?
  filename     String
  originalName String
  publicId     String?
  mimeType     String
  size         Int
  path         String
  url          String
  purpose      String?
  metadata     Json?
  storage      String   @default("local")
  createdAt    DateTime @default(now())

  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@index([tenantId])
  @@index([purpose])
}

model Shop {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  isMain    Boolean  @default(false)
  isActive  Boolean  @default(true)
  type      ShopType @default(SHOP)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashRegisters   CashRegister[]
  sales           Sale[]
  transfersFrom   StockTransfer[]  @relation("TransfersFrom")
  transfersTo     StockTransfer[]  @relation("TransfersTo")
  staff           Staff[]
  shopStocks      ShopStock[]
  users           User[]           @relation("ShopUsers")
  carpetRolls     CarpetRoll[]
  carpetCutPieces CarpetCutPiece[]
  usedPhones      UsedPhone[]
  repairTickets   RepairTicket[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model User {
  id                   String               @id @default(uuid())
  tenantId             String
  shopId               String?
  fullName             String
  email                String               @unique
  phone                String?              @unique
  passwordHash         String?
  role                 UserRole             @default(OWNER)
  isActive             Boolean              @default(true)
  emailVerified        Boolean              @default(false)
  emailVerifiedAt      DateTime?
  phoneVerified        Boolean              @default(false)
  googleId             String?              @unique
  authProvider         AuthProvider         @default(EMAIL)
  avatarUrl            String?
  passwordResetToken   String?              @unique
  passwordResetExpires DateTime?
  pushTokens           String[]             @default([])
  permissions          String[]             @default([])
  lastLoginAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  onboardingProgress   OnboardingProgress[]

  adminNotificationsRead AdminNotification[] @relation("AdminNotifReadBy")

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedShop        Shop?                   @relation("ShopUsers", fields: [shopId], references: [id], onDelete: SetNull)
  sessions            Session[]
  loginHistory        LoginHistory[]
  otps                OtpCode[]
  salesCreated        Sale[]                  @relation("UserSales")
  purchasesMade       Purchase[]              @relation("UserPurchases")
  expensesMade        Expense[]               @relation("UserExpenses")
  adjustmentsMade     StockAdjustment[]       @relation("UserAdjustments")
  ledgersCreated      CustomerLedger[]        @relation("UserLedgers")
  cashRegistersOpened CashRegister[]          @relation("UserOpenedRegisters")
  cashRegistersClosed CashRegister[]          @relation("UserClosedRegisters")
  cashTransactions    CashTransaction[]       @relation("UserCashTx")
  activityLogs        ActivityLog[]           @relation("UserActivities")
  notifications       Notification[]          @relation("UserNotifications")
  transfersCreated    StockTransfer[]         @relation("UserTransfers")
  returnsProcessed    SaleReturn[]            @relation("UserReturns")
  discountsCreated    DiscountCode[]          @relation("UserDiscounts")
  notesAuthored       TenantNote[]            @relation("UserNotes")
  settingsUpdated     SystemSetting[]         @relation("UserSettings")
  broadcasts          BroadcastNotification[] @relation("UserBroadcasts")
  platformDiscounts   PlatformDiscount[]      @relation("UserPlatformDiscounts")
  staffProfile        Staff?                  @relation("StaffUser")

  @@index([tenantId])
  @@index([tenantId, role])
  @@index([shopId])
}

model OnboardingProgress {
  id       String @id @default(uuid())
  tenantId String @unique
  userId   String

  // Progress tracking
  currentStep    Int       @default(1)
  completedSteps Int[]     @default([])
  isCompleted    Boolean   @default(false)
  isSkipped      Boolean   @default(false)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  // Step 1: Business Info
  businessType String? // KIRYANA, BAKERY, PHARMACY, MOBILE_SHOP, RESTAURANT, COSMETICS, CLOTHING, HARDWARE, STATIONERY, OTHER
  businessSize String? // SMALL, MEDIUM, LARGE
  city         String?
  province     String?

  // Step 2: Owner Profile
  avatarUrl         String?
  whatsappNumber    String?
  cnic              String? // Pakistan CNIC: 13 digits (XXXXX-XXXXXXX-X), masked
  preferredLanguage String? // ur, en, roman_ur

  // Step 3: Shop Details
  shopAddress String?
  openTime    String? // "09:00"
  closeTime   String? // "22:00"
  workingDays String[] @default([]) // ["mon","tue","wed","thu","fri","sat","sun"]
  taxNumber   String? // GST/NTN (optional)

  // Step 4: Setup Preferences
  enabledCategories String[] @default([])
  paymentMethods    String[] @default(["CASH"])
  receiptTemplate   String? // BASIC, DETAILED, THERMAL_80MM, THERMAL_58MM
  lowStockThreshold Int      @default(10)

  // Step 5: First products & data
  productsAddedCount Int @default(0)

  // Step 6: Team & finish
  teamMembersAdded Int     @default(0)
  wantsTutorial    Boolean @default(true)

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
}

model Session {
  id                String   @id @default(uuid())
  userId            String
  refreshTokenHash  String
  userAgent         String?
  ipAddress         String?
  deviceFingerprint String?  // Hash of browser+os+device for matching
  deviceName        String?  // Human-readable: "iPhone 15 - Safari"
  location          String?  // City/country from IP
  lastUsedAt        DateTime @default(now())
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceFingerprint])
  @@index([userId, deviceFingerprint])
}
model LoginHistory {
  id                String   @id @default(uuid())
  userId            String
  tenantId          String
  email             String
  success           Boolean  @default(true)
  failureReason     String?
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  deviceName        String?
  location          String?
  isNewDevice       Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([tenantId])
  @@index([createdAt])
}


model OtpCode {
  id         String    @id @default(uuid())
  userId     String?
  email      String?
  phone      String?
  code       String
  purpose    String
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([phone])
  @@index([purpose])
}

model Category {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  color     String   @default("#2c9466")
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id               String   @id @default(uuid())
  tenantId         String
  categoryId       String?
  brandId          String?
  name             String
  slug             String?
  description      String?  @db.Text
  shortDescription String?
  sku              String?
  barcode          String?
  unit             String   @default("pcs")
  price            Float    @default(0)
  costPrice        Float    @default(0)
  wholesalePrice   Float?
  taxRate          Float    @default(0)
  stock            Float    @default(0)
  lowStockAlert    Float    @default(5)
  weight           Float?
  weightUnit       String?
  dimensions       String?
  hasVariants      Boolean  @default(false)
  expiryTracked    Boolean  @default(false)
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand           Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  stockMovements  StockMovement[]
  adjustments     StockAdjustment[]
  transferItems   StockTransferItem[]
  returnItems     SaleReturnItem[]
  images          ProductImage[]
  variants        ProductVariant[]
  tags            ProductTag[]
  batches         ProductBatch[]
  productImeis    ProductImei[]
  shopStocks      ShopStock[]
  carpetRolls     CarpetRoll[]
  carpetCutPieces CarpetCutPiece[]
  repairParts     RepairPart[]        @relation("RepairPartProduct")

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
  @@index([tenantId, barcode])
  @@index([tenantId, isFeatured])
  @@index([categoryId])
  @@index([brandId])
}

model Brand {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  slug        String
  description String?  @db.Text
  logoUrl     String?
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  color     String   @default("#16a34a")
  createdAt DateTime @default(now())

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products ProductTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ProductTag {
  productId String
  tagId     String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  thumbnail String?
  alt       String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  uploadId  String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

model ProductVariant {
  id             String   @id @default(uuid())
  productId      String
  name           String
  sku            String?
  barcode        String?
  color          String?
  colorHex       String?
  size           String?
  weight         Float?
  unit           String?
  price          Float
  costPrice      Float    @default(0)
  wholesalePrice Float?
  stock          Float    @default(0)
  lowStockAlert  Float    @default(5)
  imageUrl       String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  batches         ProductBatch[]
  imeis           ProductImei[]
  saleItems       SaleItemVariant[]
  shopStocks      ShopStock[]
  carpetRolls     CarpetRoll[]
  carpetCutPieces CarpetCutPiece[]

  @@index([productId])
  @@index([productId, isActive])
  @@index([sku])
  @@index([barcode])
}

model SaleItemVariant {
  id         String   @id @default(uuid())
  saleItemId String   @unique
  variantId  String
  createdAt  DateTime @default(now())

  saleItem SaleItem       @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([variantId])
}

model ProductBatch {
  id              String    @id @default(uuid())
  tenantId        String
  productId       String
  variantId       String?
  batchNumber     String
  manufactureDate DateTime?
  expiryDate      DateTime?
  quantity        Float     @default(0)
  costPrice       Float     @default(0)
  notes           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

