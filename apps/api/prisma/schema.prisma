// ═══════════════════════════════════════════════════════════════
// MULTI-SHOP STOCK — Per-shop inventory tracking
// ═══════════════════════════════════════════════════════════════
model ShopStock {
  id        String  @id @default(uuid())
  tenantId  String
  shopId    String
  productId String
  variantId String?

  stock         Float @default(0)
  lowStockAlert Float @default(5)

  // Optional shop-specific overrides
  shopPrice     Float? // If null, use product.price
  shopCostPrice Float? // If null, use product.costPrice

  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop    Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId, variantId])
  @@index([tenantId])
  @@index([shopId])
  @@index([productId])
  @@index([variantId])
  @@index([shopId, productId])
  @@index([shopId, stock])
}

// ═══════════════════════════════════════════════════════════════
// INDUSTRY: CARPET / FLOORING — Roll-based Inventory
// ═══════════════════════════════════════════════════════════════

enum CarpetRollStatus {
  ACTIVE // Stock mein available, bik sakti hai
  FINISHED // Pura roll khatam ho gaya
  DAMAGED // Damage, sale nahi ho sakti
  RESERVED // Kisi customer ke liye reserve
  TRANSFERRED // Doosre shop mein bhej diya
}

enum CarpetCutPieceStatus {
  AVAILABLE // Bechne ke liye taiyar
  SOLD // Bik gaya
  DAMAGED // Kharab
  RESERVED // Reserve kisi customer ke liye
}

enum CarpetRollSource {
  OPENING_STOCK // Shop pehle se chal rahi, opening entry
  PURCHASE // Supplier se kharida
  TRANSFER_IN // Doosre shop se aaya
  RETURN // Customer ne wapas kiya (kabhi kabhi)
  ADJUSTMENT // Manual adjustment
}

enum CarpetCutPieceSource {
  LEFTOVER // Sale ke baad bacha tukra
  CUSTOMER_RETURN // Customer ne return kiya
  DAMAGED_ROLL // Damaged roll se nikla
  OPENING_STOCK // Opening entry
  MANUAL // Manually added
}

model CarpetRoll {
  id        String  @id @default(uuid())
  tenantId  String
  shopId    String?
  productId String
  variantId String?

  // ─── Roll Identity ───────────────────────────────────────
  rollNumber String // R-001, SF-CR-2026-001, supplier ka roll # — kuch bhi
  designCode String? // Supplier ka design code (e.g. "SF-2024-A")

  // ─── Dimensions (Pakistani shop format: feet + inches separate) ──
  widthFt             Float @default(12) // Whole feet portion
  widthInch           Float @default(0)  // Inches portion (0-11)
  originalLengthFt    Float              // Whole feet portion
  originalLengthInch  Float @default(0)  // Inches portion (0-11)
  remainingLengthFt   Float              // Whole feet remaining
  remainingLengthInch Float @default(0)  // Inches remaining (0-11)

  // ─── Auto-calculated Sqft (real decimal math) ──────
  // Formula: (widthFt + widthInch/12) × (lengthFt + lengthInch/12)
  originalSqft  Float @default(0)
  remainingSqft Float @default(0)

  // ─── Pricing ─────────────────────────────────────────────
  costPerSqft           Float  @default(0)
  salePricePerSqft      Float  @default(0)
  wholesalePricePerSqft Float?

  // ─── Status & Source ─────────────────────────────────────
  status     CarpetRollStatus @default(ACTIVE)
  sourceType CarpetRollSource @default(OPENING_STOCK)

  // ─── Reference Links ─────────────────────────────────────
  purchaseId     String? // Agar purchase se aaya
  purchaseItemId String?
  supplierId     String? // Direct supplier link (optional)

  // ─── Location ────────────────────────────────────────────
  rackNumber String? // R-1, Wall-2, Godown-A
  notes      String? @db.Text

  // ─── Quality / Grade (optional) ──────────────────────────
  quality String? // "Premium", "Standard", "Economy"
  pile    String? // "Wool", "Synthetic", "Mixed"

  // ─── Lifecycle ───────────────────────────────────────────
  receivedAt  DateTime  @default(now())
  finishedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ─── Relations ───────────────────────────────────────────
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop          Shop?                @relation(fields: [shopId], references: [id], onDelete: SetNull)
  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant       ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  cutPieces     CarpetCutPiece[]     @relation("RollToCutPieces")
  movements     CarpetRollMovement[]
  transferItems StockTransferItem[]

  @@unique([tenantId, rollNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([shopId])
  @@index([productId])
  @@index([variantId])
  @@index([tenantId, shopId, status])
  @@index([rollNumber])
}

model CarpetCutPiece {
  id        String  @id @default(uuid())
  tenantId  String
  shopId    String?
  productId String
  variantId String?

  // ─── Source ──────────────────────────────────────────────
  sourceRollId String? // Kis roll se nikla (null = customer return / opening)
  sourceType   CarpetCutPieceSource @default(LEFTOVER)

  // ─── Identity ────────────────────────────────────────────
  pieceCode String // CP-001, CP-2026-001

  // ─── Dimensions ──────────────────────────────────────────
  widthFt    Float @default(0)
  widthInch  Float @default(0)
  lengthFt   Float @default(0)
  lengthInch Float @default(0)
  totalSqft  Float @default(0) // Auto calculated

  // ─── Pricing ─────────────────────────────────────────────
  costAmount   Float  @default(0) // Total cost (lump sum)
  salePrice    Float  @default(0) // Flat price (cut pieces usually discount pe)
  pricePerSqft Float? // Optional: agar sqft basis pe bechna ho

  // ─── Status ──────────────────────────────────────────────
  status    CarpetCutPieceStatus @default(AVAILABLE)
  condition String? // "Good", "Slight damage", "Edge worn"

  // ─── Location & Notes ────────────────────────────────────
  rackNumber String?
  notes      String? @db.Text

  // ─── Sale Tracking ───────────────────────────────────────
  saleItemId String?   @unique
  soldAt     DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ─── Relations ───────────────────────────────────────────
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop       Shop?           @relation(fields: [shopId], references: [id], onDelete: SetNull)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  sourceRoll CarpetRoll?     @relation("RollToCutPieces", fields: [sourceRollId], references: [id], onDelete: SetNull)

  @@unique([tenantId, pieceCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([shopId])
  @@index([productId])
  @@index([sourceRollId])
}

model CarpetRollMovement {
  id       String @id @default(uuid())
  rollId   String
  tenantId String

  type               String // CUT_FOR_SALE, ADJUSTMENT, TRANSFER, RETURN, DAMAGE, OPENING
  lengthFt           Float // Kitni length affect hui (+/-)
  sqft               Float // Auto calculated
  balanceLengthAfter Float // Movement ke baad kitna bacha
  balanceSqftAfter   Float

  reference   String? // saleId, transferId, etc.
  saleId      String?
  saleItemId  String?
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  roll      CarpetRoll @relation(fields: [rollId], references: [id], onDelete: Cascade)
  saleItem  SaleItem?  @relation(fields: [saleItemId], references: [id], onDelete: SetNull)

  @@index([rollId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([saleId])
  @@index([saleItemId])
}

// ═══════════════════════════════════════════════════════════════
// INDUSTRY: MOBILE — Used Phone Trade-In System
// ═══════════════════════════════════════════════════════════════

model UsedPhone {
  id       String  @id @default(uuid())
  tenantId String
  shopId   String?

  // ─── Identification ────────────────────────────────────
  usedPhoneCode String // UP-2026-0001 — auto-generated
  imei1         String // Primary IMEI
  imei2         String? // Dual SIM
  serialNumber  String?

  // ─── Device info ───────────────────────────────────────
  brand     String // Apple, Samsung, etc.
  model     String // iPhone 13 Pro, Galaxy S22, etc.
  storage   String? // 128GB, 256GB
  ram       String? // 6GB, 8GB
  color     String?
  modelYear Int? // 2021, 2022, etc.

  // ─── PTA Status ────────────────────────────────────────
  ptaStatus  PtaStatus @default(PENDING)
  ptaTaxPaid Float     @default(0)

  // ─── Condition & Inspection ────────────────────────────
  condition      UsedPhoneCondition @default(GOOD)
  conditionNotes String?            @db.Text

  // Accessories checklist
  hasOriginalBox       Boolean   @default(false)
  hasOriginalCharger   Boolean   @default(false)
  hasOriginalCable     Boolean   @default(false)
  hasOriginalEarphones Boolean   @default(false)
  hasOriginalReceipt   Boolean   @default(false)
  hasWarrantyLeft      Boolean   @default(false)
  warrantyExpiryDate   DateTime?

  // ─── Trade-In Pricing ──────────────────────────────────
  source         TradeInSource @default(CASH_BUYBACK)
  buybackPrice   Float         @default(0) // What we paid customer
  estimatedValue Float         @default(0) // System suggested value
  refurbishCost  Float         @default(0) // Repair/cleaning cost
  totalCost      Float         @default(0) // buybackPrice + refurbishCost
  resalePrice    Float         @default(0) // Listed sale price
  finalSoldPrice Float? // Actual sold price

  // ─── Customer Info (trade-in source) ───────────────────
  fromCustomerId    String?
  fromCustomerName  String?
  fromCustomerPhone String?
  fromCustomerCnic  String? // 13-digit CNIC
  cnicPhotoUrl      String?

  // ─── Status & Sale Tracking ────────────────────────────
  status           UsedPhoneStatus @default(PENDING_INSPECTION)
  soldToCustomerId String?
  soldSaleId       String?         @unique
  soldAt           DateTime?

  // ─── Photos & Documents ────────────────────────────────
  imeiPhotoUrl String?
  devicePhotos String[]  @default([])
  receivedAt   DateTime  @default(now())
  inspectedAt  DateTime?
  notes        String?   @db.Text

  createdById   String?
  inspectedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ─── Relations ─────────────────────────────────────────
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop         Shop?                 @relation(fields: [shopId], references: [id], onDelete: SetNull)
  fromCustomer Customer?             @relation("UsedPhoneFromCustomer", fields: [fromCustomerId], references: [id], onDelete: SetNull)
  inspections  UsedPhoneInspection[]

  @@unique([tenantId, usedPhoneCode])
  @@unique([tenantId, imei1])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, condition])
  @@index([shopId])
  @@index([fromCustomerId])
  @@index([imei1])
}

model UsedPhoneInspection {
  id          String @id @default(uuid())
  usedPhoneId String
  tenantId    String

  // Inspection checks
  screenCondition        String? // No scratch / Minor / Heavy / Cracked
  bodyCondition          String?
  cameraWorks            Boolean? @default(true)
  speakerWorks           Boolean? @default(true)
  microphoneWorks        Boolean? @default(true)
  chargingPortWorks      Boolean? @default(true)
  buttonsWork            Boolean? @default(true)
  faceIdFingerprintWorks Boolean? @default(true)
  batteryHealth          Int? // 0-100%
  imeiUnlocked           Boolean? @default(true)
  icloudUnlocked         Boolean? @default(true)
  softwareIssues         String?  @db.Text

  // Repair recommendation
  needsRepair         Boolean @default(false)
  estimatedRepairCost Float   @default(0)
  recommendedActions  String? @db.Text

  inspectedById String?
  inspectedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  usedPhone UsedPhone @relation(fields: [usedPhoneId], references: [id], onDelete: Cascade)

  @@index([usedPhoneId])
  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════
// INDUSTRY: MOBILE — Repair Service Tickets
// ═══════════════════════════════════════════════════════════════

model RepairTicket {
  id       String  @id @default(uuid())
  tenantId String
  shopId   String?

  // ─── Identification ────────────────────────────────────
  ticketNumber String // RT-2026-0001
  imei1        String?
  imei2        String?
  serialNumber String?

  // ─── Device Info ───────────────────────────────────────
  deviceBrand   String // Apple, Samsung
  deviceModel   String // iPhone 12, Galaxy S20
  deviceColor   String?
  passcode      String? // Customer's screen lock (with consent)
  hasSimCard    Boolean @default(false)
  hasMemoryCard Boolean @default(false)

  // ─── Customer Info ─────────────────────────────────────
  customerId      String?
  customerName    String
  customerPhone   String
  customerCnic    String?
  customerAddress String?

  // ─── Issue & Diagnosis ─────────────────────────────────
  reportedIssue      String  @db.Text // What customer says
  diagnosedIssue     String? @db.Text // Technician's finding
  diagnosisNotes     String? @db.Text
  recommendedActions String? @db.Text

  // ─── Status & Priority ─────────────────────────────────
  status        RepairStatus        @default(RECEIVED)
  priority      RepairPriority      @default(NORMAL)
  paymentStatus RepairPaymentStatus @default(PENDING)

  // ─── Pricing ───────────────────────────────────────────
  estimatedCost Float @default(0)
  partsCost     Float @default(0)
  laborCost     Float @default(0)
  totalCost     Float @default(0)
  advancePaid   Float @default(0)
  paidAmount    Float @default(0)
  balanceDue    Float @default(0)
  discount      Float @default(0)

  // ─── Timeline ──────────────────────────────────────────
  receivedAt       DateTime  @default(now())
  diagnosedAt      DateTime?
  approvedAt       DateTime?
  startedAt        DateTime?
  readyAt          DateTime?
  deliveredAt      DateTime?
  estimatedReadyAt DateTime?

  // ─── Assignment ────────────────────────────────────────
  technicianId   String?
  technicianName String?

  // ─── Photos ────────────────────────────────────────────
  beforePhotos String[] @default([])
  afterPhotos  String[] @default([])
  signatureUrl String? // Customer signature on receipt

  // ─── Notifications ─────────────────────────────────────
  smsNotificationsSent Int       @default(0)
  lastSmsSentAt        DateTime?

  // ─── Misc ──────────────────────────────────────────────
  notes        String?   @db.Text
  warrantyDays Int       @default(7) // Repair warranty
  warrantyEnds DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ─── Relations ─────────────────────────────────────────
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop      Shop?             @relation(fields: [shopId], references: [id], onDelete: SetNull)
  customer  Customer?         @relation("RepairTicketCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  parts     RepairPart[]
  statusLog RepairStatusLog[]
  payments  RepairPayment[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([customerId])
  @@index([shopId])
  @@index([imei1])
}

model RepairPart {
  id        String  @id @default(uuid())
  ticketId  String
  productId String? // Link to inventory product if available

  partName   String
  partNumber String?
  quantity   Float   @default(1)
  unitCost   Float   @default(0)
  unitPrice  Float   @default(0)
  totalPrice Float   @default(0)
  source     String? // 'OWN_STOCK' / 'PURCHASED_FOR_REPAIR' / 'CUSTOMER_PROVIDED'

  notes     String?
  createdAt DateTime @default(now())

  ticket  RepairTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  product Product?     @relation("RepairPartProduct", fields: [productId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([productId])
}

model RepairStatusLog {
  id          String        @id @default(uuid())
  ticketId    String
  fromStatus  RepairStatus?
  toStatus    RepairStatus
  note        String?       @db.Text
  changedById String?
  changedAt   DateTime      @default(now())

  ticket RepairTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([changedAt])
}

model RepairPayment {
  id            String        @id @default(uuid())
  ticketId      String
  amount        Float
  paymentMethod PaymentMethod @default(CASH)
  reference     String?
  notes         String?
  paidAt        DateTime      @default(now())
  createdById   String?

  ticket RepairTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}
