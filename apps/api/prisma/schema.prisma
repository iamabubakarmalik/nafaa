enum RepairStatus {
  RECEIVED // Customer ne diya, pending diagnosis
  DIAGNOSED // Issue identified, estimate ready
  AWAITING_APPROVAL // Customer ko estimate diya, approval pending
  AWAITING_PARTS // Parts order kiye hain
  IN_PROGRESS // Repair ho rahi hai
  READY // Repair done, customer ko inform
  DELIVERED // Customer le gaya
  CANCELLED // Cancel
  UNREPAIRABLE // Repair possible nahi
}

enum RepairPriority {
  NORMAL
  URGENT
  EMERGENCY
}

enum RepairPaymentStatus {
  PENDING
  ADVANCE_PAID
  FULLY_PAID
}

enum UsedPhoneCondition {
  EXCELLENT // 10/10 — like new
  VERY_GOOD // 9/10 — minor wear
  GOOD // 8/10 — visible scratches
  FAIR // 6-7/10 — heavy use, works fine
  POOR // <6/10 — needs repair
}

enum UsedPhoneStatus {
  PENDING_INSPECTION // Just received, not yet inspected
  IN_STOCK // Inspected & ready for resale
  REPAIRING // Sent for repair before resale
  SOLD // Resold to customer
  RETURNED // Customer returned (warranty/issue)
  DISCARDED // Beyond repair / scrapped
}

enum TradeInSource {
  CASH_BUYBACK // Pure buyback, customer got cash
  EXCHANGE // Traded for a new phone purchase
  CONSIGNMENT // Shop selling on behalf of customer
}

enum PtaStatus {
  APPROVED // PTA approved, no tax due
  NON_PTA // Imported, tax not paid
  PATCH // Patched / non-genuine PTA
  PENDING // Registration in progress
  EXEMPT // Local manufactured / exempt
}

enum ImeiStatus {
  IN_STOCK
  SOLD
  RETURNED
  DAMAGED
  RESERVED
  LOST
}

model ProductImei {
  id           String  @id @default(uuid())
  tenantId     String
  productId    String
  variantId    String?
  imei1        String // Primary IMEI (15 digits)
  imei2        String? // Dual SIM second IMEI
  serialNumber String? // For non-IMEI electronics

  // ─── PTA Compliance (Pakistan-specific) ──────────────
  ptaStatus     PtaStatus @default(PENDING)
  ptaTaxPaid    Float     @default(0)
  ptaTaxDueAt   DateTime?
  ptaVerifiedAt DateTime?

  // Stock info
  status    ImeiStatus @default(IN_STOCK)
  costPrice Float      @default(0)

  // Sale tracking
  saleItemId String?   @unique
  soldAt     DateTime?
  soldPrice  Float?

  // Warranty
  warrantyMonths Int?      @default(12)
  warrantyExpiry DateTime?

  // Purchase tracking
  purchaseItemId String?
  purchasedAt    DateTime?

  // Misc
  color String?
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([tenantId, imei1])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ptaStatus])
  @@index([productId])
  @@index([variantId])
  @@index([imei1])
  @@index([saleItemId])
}

// ═══════════════════════════════════════════════════════════════
