// ===================================================================
// TENANT SETTINGS — Complete configuration per shop
// ===================================================================
model TenantSettings {
  id       String @id @default(uuid())
  tenantId String @unique

  // ===== 1. BUSINESS PROFILE =====
  shopName       String?
  legalName      String?
  shopAddress    String?
  shopCity       String?
  shopProvince   String?
  shopPostalCode String?
  shopPhone      String?
  shopWhatsapp   String?
  shopEmail      String?
  shopWebsite    String?
  logoUrl        String?
  bannerUrl      String?
  businessType   String?
  establishedDate DateTime?

  // ===== 2. LOCALIZATION =====
  language         String  @default("roman_ur") // ur, en, roman_ur
  currency         String  @default("PKR")
  currencySymbol   String  @default("Rs")
  timezone         String  @default("Asia/Karachi")
  dateFormat       String  @default("DD/MM/YYYY")
  firstDayOfWeek   String  @default("monday")
  openTime         String? // "09:00"
  closeTime        String? // "22:00"
  workingDays      String[] @default(["mon","tue","wed","thu","fri","sat"])

  // ===== 3. TAX & PRICING =====
  enableTax        Boolean @default(false)
  taxRate          Float   @default(0)
  taxInclusive     Boolean @default(false)
  taxNumber        String?
  taxLabel         String  @default("GST")
  defaultMarkup    Float   @default(0)
  roundPriceTo     Int     @default(1) // round to nearest 1, 5, 10

  // ===== 4. RECEIPT & INVOICE =====
  receiptSize         String  @default("THERMAL_58MM") // THERMAL_58MM, THERMAL_80MM, A4_BASIC, A4_DETAILED
  receiptHeader       String?
  receiptFooter       String?
  receiptShowLogo     Boolean @default(true)
  receiptShowTax      Boolean @default(true)
  receiptShowCustomer Boolean @default(true)
  receiptShowBarcode  Boolean @default(false)
  receiptShowQrCode   Boolean @default(false)
  invoicePrefix       String  @default("INV-")
  invoiceStartNumber  Int     @default(1)
  autoPrintReceipt    Boolean @default(false)
  printCopiesCount    Int     @default(1)

  // ===== 5. POS SETTINGS =====
  defaultPaymentMethod String  @default("CASH")
  allowNegativeStock   Boolean @default(false)
  confirmBeforeCheckout Boolean @default(true)
  requireCustomerForSale Boolean @default(false)
  allowDiscount        Boolean @default(true)
  maxDiscountPercent   Float   @default(50)
  roundTotal           Boolean @default(true)
  showProductImages    Boolean @default(true)
  enableBarcodeScanner Boolean @default(true)
  enableQuickKeys      Boolean @default(true)

  // ===== 6. INVENTORY =====
  defaultLowStockAlert Int     @default(10)
  trackExpiry          Boolean @default(false)
  expiryWarningDays    Int     @default(30)
  stockMethod          String  @default("AVERAGE") // FIFO, LIFO, AVERAGE
  autoReorder          Boolean @default(false)
  reorderPoint         Int     @default(5)

  // ===== 7. CUSTOMER & UDHAAR =====
  allowCredit          Boolean @default(true)
  defaultCreditLimit   Float   @default(0)
  creditOverdueDays    Int     @default(30)
  enableLoyalty        Boolean @default(false)
  loyaltyPointsPerRupee Float  @default(0.01) // 1 point per Rs 100
  loyaltyRedemptionRate Float  @default(1)    // 1 point = Rs 1
  autoCreateCustomer   Boolean @default(false)

  // ===== 8. NOTIFICATIONS =====
  emailNotifications     Boolean @default(true)
  smsNotifications       Boolean @default(false)
  whatsappNotifications  Boolean @default(false)
  pushNotifications      Boolean @default(true)
  notifyLowStock         Boolean @default(true)
  notifyOutOfStock       Boolean @default(true)
  notifyNewSale          Boolean @default(false)
  notifyDailySummary     Boolean @default(true)
  dailySummaryTime       String  @default("21:00")
  notifyNewCustomer      Boolean @default(false)

  // ===== 9. SECURITY =====
  requirePinForVoid     Boolean @default(false)
  requirePinForDiscount Boolean @default(false)
  requirePinForRefund   Boolean @default(true)
  managerPin            String?
  autoLogoutMinutes     Int     @default(60)
  enableTwoFactor       Boolean @default(false)
  maxLoginAttempts      Int     @default(5)

  // ===== 10. APPEARANCE =====
  theme        String  @default("light") // light, dark, auto
  brandColor   String  @default("#16a34a")
  compactMode  Boolean @default(false)

  // ===== METADATA =====
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
