{
  "name": "@nafaa/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "eas-build-pre-install": "npm install -g pnpm@11.0.8 && cd ../.. && pnpm install --frozen-lockfile && rm -rf packages/shared-ui/node_modules packages/shared-hooks/node_modules packages/shared-types/node_modules packages/shared-utils/node_modules packages/api-client/node_modules || true"
  },
