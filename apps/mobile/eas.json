{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_ENV": "development",
        "PNPM_VERSION": "11.0.8"
      },
      "ios": {
        "resourceClass": "m-medium",
        "simulator": true,
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "medium",
        "image": "latest"
      },
      "node": "22.13.0"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_ENV": "staging",
        "EXPO_PUBLIC_API_URL": "https://staging-api.nafaa.pk/api",
        "PNPM_VERSION": "11.0.8"
      },
      "ios": {
        "resourceClass": "m-medium",
        "simulator": false,
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "medium",
        "image": "latest"
      },
      "node": "22.13.0"
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.nafaa.pk/api",
        "EXPO_PUBLIC_APP_URL": "https://nafaa.pk",
        "PNPM_VERSION": "11.0.8"
      },
      "ios": {
        "resourceClass": "m-medium",
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "medium",
        "image": "latest"
      },
      "node": "22.13.0"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "rashdan@natiq.se",
        "ascAppId": "6769007778",
        "appleTeamId": "A48F33D4Q8"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}